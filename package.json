{
  "name": "bluetang",
  "version": "0.4.0",
  "description": "Proxy intelligent entre client LLM et Ollama — RAG + mémoire + client MCP",
  "author": "OnyxynO <etievant.sebastien@protonmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OnyxynO/BlueTang.git"
  },
  "homepage": "https://github.com/OnyxynO/BlueTang#readme",
  "keywords": [
    "llm",
    "ollama",
    "rag",
    "mcp",
    "proxy",
    "local-ai",
    "continue"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "bluetang": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --target node22 --clean",
    "pretest": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "commander": "^12.0.0",
    "hono": "^4.6.0",
    "ignore": "^7.0.5",
    "sqlite-vec": "^0.1.7-alpha.2",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-php": "^0.22.8",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.4"
  }
}
